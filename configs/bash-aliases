alias cls='clear; ls'
alias dc='docker compose'
alias dudo='sudo -u dockeruser'

alias yt-dlpen='yt-dlp --write-sub --sub-lang "en.*"'
alias yt-dlpen-auto='yt-dlp --write-auto-sub --sub-lang "en.*"'
alias yt-dlpp='yt-dlp -o '\''%(playlist)s/%(playlist_index)05d___%(title)s.%(ext)s'\'''

alias mpvv="mpv --script='$HOME/etc/scripts-and-configs/helpers/mpv-saver/saver.js'"
alias mpvs='mpvv --shuffle'
alias ssort="$HOME/etc/scripts-and-configs/helpers/mpv-saver/sort.mjs"

# vim: ft=bash
